{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "food-log",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-03",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "food-log-db",
      "database_id": "replace-with-your-d1-database-id",
      "migrations_dir": "migrations"
    }
  ]
}
